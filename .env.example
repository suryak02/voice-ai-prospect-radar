# Supabase Postgres connection string
# Example: postgresql://postgres.<project-ref>:***@aws-0-eu-west-2.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1
DATABASE_URL=

# Google Places API key for real data ingestion + live server-side search.
# Enable Places API (New) in Google Cloud, then run: npm run ingest:places
GOOGLE_MAPS_API_KEY=

# Client-side Google Maps JS key (renders the map). Usually the same key,
# restricted by HTTP referrer in Google Cloud.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# OpenAI key for on-demand AI prospect analysis (personalized summary + outreach
# angle). Results are cached in the DB with a 7-day cooldown to control cost.
OPENAI_API_KEY=
# Optional: override the model (defaults to a cheap mini model).
# OPENAI_MODEL=gpt-4o-mini

# Upstash Redis for shared (global) rate limiting across serverless instances.
# Create a free Upstash Redis DB and paste its REST URL + token. If unset, rate
# limiting falls back to a best-effort in-memory limiter (per instance).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Whole-site password gate with two access tiers (src/proxy.ts). If SITE_PASSWORD
# is unset the site is open. admin = full access including deep web research.
SITE_USERNAME=
SITE_PASSWORD=
# demo tier = standard access only (no deep research).
DEMO_USERNAME=
DEMO_PASSWORD=

# Optional: semicolon-separated search queries. Defaults are London dental/aesthetics/veterinary searches.
# PLACES_QUERIES=dentist in Hackney London;aesthetic clinic in Shoreditch London;veterinary clinic in Tower Hamlets London
# PLACES_RESULT_LIMIT=8
