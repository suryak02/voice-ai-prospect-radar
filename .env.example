# Supabase Postgres connection string
# Example: postgresql://postgres.<project-ref>:***@aws-0-eu-west-2.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1
DATABASE_URL=

# Google Places API key for server side search and ingestion.
GOOGLE_MAPS_API_KEY=

# Browser Google Maps JS key. Restrict this by HTTP referrer in Google Cloud.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# OpenAI key for prospect analysis. Results are cached to control cost.
OPENAI_API_KEY=

# Optional: override the model.
# OPENAI_MODEL=gpt-4o-mini

# Upstash Redis for shared rate limiting and short lived search caching.
# If unset, local development falls back to in memory rate limits/cache.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Whole site password gate with two access tiers.
# If SITE_PASSWORD is unset, the site is open.
SITE_USERNAME=
SITE_PASSWORD=
DEMO_USERNAME=
DEMO_PASSWORD=

# Optional ingestion settings.
# PLACES_QUERIES=dentist in Hackney London;aesthetic clinic in Shoreditch London;veterinary clinic in Tower Hamlets London
# PLACES_RESULT_LIMIT=8
